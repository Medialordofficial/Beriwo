rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /conversations/{convoId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    match /user_memory/{userId} {
      allow read, write: if request.auth != null;

      match /facts/{factId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
